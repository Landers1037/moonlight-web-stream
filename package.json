{
  "name": "moonlight-web",
  "version": "1.0.0",
  "description": "",
  "main": "web/index.ts",
  "watch": {
    "build-light": {
      "patterns": [
        "src",
        "web"
      ],
      "extensions": "ts,html,css,svg,png,rs",
      "ignore": "web/api_bindings.d.ts",
      "runOnChangeOnly": false
    }
  },
  "scripts": {
    "dev": "npm run generate-bindings && npm-watch build-light",
    "build": "npm run generate-bindings && npm run build-light",
    "build-css": "npx tailwindcss -i ./web/styles/tailwind-input.css -o ./web/styles/standard.css && npx tailwindcss -i ./web/styles/tailwind-input.css -o ./web/styles/moonlight.css",
    "build-light": "npm run build-css && tsc && npm run copy-static",
    "generate-bindings": "cargo test export_bindings --package common",
    "copy-static": "cpx \"web/**/*.{html,json,css,svg,png,js,wasm}\" static/"
  },
  "license": "GPL-3.0-or-later",
  "private": "true",
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "cpx": "1.2.1",
    "npm-watch": "0.13.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3"
  }
}
